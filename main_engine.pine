//@version=6
indicator("MAIN ENGINE – CORE CLEAN", overlay=true)

// =====================================================
// EMA
// =====================================================
emaFast = ta.ema(close, 5)
emaSlow = ta.ema(close, 20)
emaMid = ta.ema(close, 50)

plot(emaFast, color=color.white, linewidth=1, title="EMA 5")
plot(emaSlow, color=color.orange,   linewidth=1, title="EMA 20")
plot(emaMid, color=color.blue,   linewidth=1, title="EMA 50")

// =====================================================
// PARABOLIC SAR
// =====================================================
psarStart = input.float(0.02, "PSAR Start")
psarInc   = input.float(0.02, "PSAR Increment")
psarMax   = input.float(0.2,  "PSAR Max")

psar = ta.sar(psarStart, psarInc, psarMax)
plot(psar, style=plot.style_circles, linewidth=1, color=color.white, title="PSAR")

// =====================================================
// SUPERTREND
// =====================================================
stFactor = input.float(3.0, "SuperTrend Factor")
stATR    = input.int(10, "SuperTrend ATR")

[st, dir] = ta.supertrend(stFactor, stATR)
plot(st, color = dir < 0 ? color.green : color.red, linewidth=1, title="SuperTrend")
